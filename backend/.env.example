# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neonova

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI (optional, used when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# LLM Provider selection: "openai" or "azure"
LLM_PROVIDER=openai
