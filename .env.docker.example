# Database Configuration
POSTGRES_USER=neonova
POSTGRES_PASSWORD=neonova_dev_password
POSTGRES_DB=neonova

# Backend Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# LLM Provider Configuration
# Options: openai, azure_openai
LLM_PROVIDER=openai

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Azure OpenAI Configuration (if using Azure OpenAI)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# Debug Mode (set to true for development)
DEBUG=false
